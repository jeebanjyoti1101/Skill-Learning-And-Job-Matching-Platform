# ============================================================
# AI CHATBOT APIs (Choose one or use all for fallback)
# ============================================================

# OPTION 1: Google Gemini (RECOMMENDED - FREE!)
# Get your key from: https://makersuite.google.com/app/apikey
# Free tier: 1500 requests/day, fast & reliable
GEMINI_API_KEY=your_gemini_api_key_here

# OPTION 2: OpenAI GPT (Most Powerful)
# Get your key from: https://platform.openai.com/api-keys
# Cost: ~$0.01 per 1K tokens (GPT-3.5) or ~$0.03 per 1K (GPT-4)
OPENAI_API_KEY=your_openai_api_key_here

# OPTION 2B: Hugging Face Router (OpenAI-compatible chat API)
# Get your key from: https://huggingface.co/settings/tokens
# Example model: Qwen/Qwen2.5-7B-Instruct:together
HF_ROUTER_API_KEY=your_hf_router_api_key_here
HF_CHAT_MODEL=Qwen/Qwen2.5-7B-Instruct:together

# OPTION 3: Anthropic Claude (Long Context)
# Get your key from: https://console.anthropic.com/
# Cost: ~$0.003-0.015 per 1K tokens
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OPTION 4: Ollama (Local - No key needed!)
# Just install from: https://ollama.com/download
# Then run: ollama pull llama3.2:3b
OLLAMA_HOST=http://localhost:11434

# Chatbot Mode: gemini, openai, claude, ollama, rule-based, hybrid
CHATBOT_MODE=hybrid

